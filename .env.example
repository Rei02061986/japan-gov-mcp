# japan-gov-mcp 環境変数
# コピーして .env として使用: cp .env.example .env

# ─── 必須（Tier 1: 統計基盤）───
# e-Stat API アプリケーションID
# 取得: https://www.e-stat.go.jp/api/api-dev/how_to_use
ESTAT_APP_ID=

# ─── 推奨（Tier 2: 法人・金融）───
# 法人番号 API アプリケーションID
# 取得: https://www.houjin-bangou.nta.go.jp/webapi/
HOUJIN_APP_ID=

# gBizINFO API トークン
# 取得: https://info.gbiz.go.jp/hojin/api
GBIZ_TOKEN=

# EDINET API Subscription Key
# 取得: https://disclosure2.edinet-fsa.go.jp/
EDINET_API_KEY=

# ─── オプション（Tier 3）───
# 国交省データプラットフォーム API Key
# 取得: https://www.mlit-data.jp/
MLIT_DPF_API_KEY=

# 不動産情報ライブラリ API Key
# 取得: https://www.reinfolib.mlit.go.jp/
REALESTATE_API_KEY=

# ハローワーク求人API キー
HELLOWORK_API_KEY=

# ─── ログ設定（オプション）───
# JAPAN_GOV_MCP_LOG=false
# JAPAN_GOV_MCP_LOG_DIR=/custom/path/to/logs

# ─── APIキー不要で利用可能 ───
# 統計ダッシュボード WebAPI, 日本銀行時系列統計, NDB OpenData Hub
# 法令API (e-Gov), 気象庁防災情報, J-SHIS 地震ハザード
# 国土地理院 ジオコーディング, 国会会議録, そらまめくん
# 海外安全情報, データカタログ (data.go.jp), G空間情報センター
