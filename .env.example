# japan-gov-mcp 環境変数
# コピーして .env として使用: cp .env.example .env

# ─── 必須（Tier 1: 統計基盤）───
# e-Stat API アプリケーションID
# 取得: https://www.e-stat.go.jp/api/api-dev/how_to_use
ESTAT_APP_ID=

# RESAS API キー
# 取得: https://opendata.resas-portal.go.jp/
RESAS_API_KEY=

# ─── 推奨（Tier 2: 法人・金融）───
# 法人番号 API アプリケーションID
# 取得: https://www.houjin-bangou.nta.go.jp/webapi/
HOUJIN_APP_ID=

# gBizINFO API トークン
# 取得: https://info.gbiz.go.jp/hojin/api
GBIZ_TOKEN=

# EDINET API Subscription Key
# 取得: https://disclosure2.edinet-fsa.go.jp/
EDINET_API_KEY=

# 特許情報API
# EPO OPS (欧州特許庁) — 日本特許含む: https://developers.epo.org/
EPO_CONSUMER_KEY=
EPO_CONSUMER_SECRET=
# Lens.org — 非商用無料: https://www.lens.org/lens/user/apikey
LENS_API_TOKEN=

# ─── オプション ───
# ハローワーク求人API キー
HELLOWORK_API_KEY=

# ─── APIキー不要で利用可能 ───
# 統計ダッシュボード WebAPI
# 法令API (e-Gov)
# 不動産情報ライブラリAPI
# データカタログサイトAPI (data.go.jp)
# 海外安全情報オープンデータ
# 文化遺産オンライン検索用API
