{
  "name": "japan-gov-mcp",
  "version": "1.0.0",
  "description": "日本政府API統合MCPサーバー - 30+ API / 90ツール（シナリオ複合9個）で中央省庁のオープンデータに統合アクセス",
  "type": "module",
  "bin": {
    "japan-gov-mcp": "./build/index.js"
  },
  "scripts": {
    "build": "tsc && rm -rf build/data && cp -r src/data build/data 2>/dev/null; chmod 755 build/index.js",
    "start": "node build/index.js",
    "typecheck": "tsc --noEmit",
    "test": "node --test 'tests/*.test.ts'",
    "test:e2e": "node --test 'tests/e2e/**/*.test.ts'",
    "test:all": "node --test 'tests/**/*.test.ts'",
    "inspect": "npx @modelcontextprotocol/inspector node build/index.js",
    "prepublishOnly": "npm run build && npm test"
  },
  "files": ["build"],
  "keywords": [
    "mcp", "mcp-server", "japan", "government", "statistics",
    "e-stat", "resas", "opendata", "api", "claude"
  ],
  "license": "MIT",
  "author": "reikumaki",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reikumaki/japan-gov-mcp.git"
  },
  "homepage": "https://github.com/reikumaki/japan-gov-mcp#readme",
  "bugs": {
    "url": "https://github.com/reikumaki/japan-gov-mcp/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "typescript": "^5.8.3"
  }
}
